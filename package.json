{
  "name": "@eikeon/nostr-relay",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "NIP-01 NOSTR relay - WebSocket server built with Effect v4",
  "author": "Daniel Krech <eikeon@eikeon.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepare": "effect-language-service patch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" && tsc --noEmit",
    "smoke": "bash scripts/smoke-test.sh",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.10",
    "effect": "4.0.0-beta.10",
    "nostr-tools": "^2.23.1"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.75.1",
    "@effect/vitest": "^4.0.0-beta.10",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
