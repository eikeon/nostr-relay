{
  "name": "nostr-relay-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @eikeon/nostr-relay dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "smoke": "pnpm --filter @eikeon/nostr-relay smoke",
    "cdk": "pnpm --filter @eikeon/nostr-relay-aws cdk",
    "cdk:bootstrap": "pnpm --filter @eikeon/nostr-relay-aws cdk:bootstrap",
    "cdk:deploy": "pnpm --filter @eikeon/nostr-relay-aws cdk:deploy"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
